package Logica;

import java.util.ArrayList;
import java.util.Date;
import java.util.List;

public class Prestamo {
	    private String id; 
	    private Date fechaPrestamo;
	    private Date fechaDevolucion;
	    private String estado; 
	    private Personas solicitante; 
	    private List<Item> itemsPrestados;

	    public Prestamo(String id, Date fechaPrestamo, Date fechaDevolucion, Personas solicitante, List<Item> itemsPrestados) {
	        this.id = id;
	        this.fechaPrestamo = fechaPrestamo;
	        this.fechaDevolucion = fechaDevolucion;
	        this.estado = "Activo"; 
	        this.solicitante = solicitante;
	        this.itemsPrestados = itemsPrestados != null ? itemsPrestados : new ArrayList<>();
	    }
  public String getId() { return id; }
	    public void setId(String id) { this.id = id; }

	    public Date getFechaPrestamo() { return fechaPrestamo; }
	    public void setFechaPrestamo(Date fechaPrestamo) { this.fechaPrestamo = fechaPrestamo; }

	    public Date getFechaDevolucion() { return fechaDevolucion; }
	    public void setFechaDevolucion(Date fechaDevolucion) { this.fechaDevolucion = fechaDevolucion; }

	    public String getEstado() { return estado; }
	    public void setEstado(String estado) { this.estado = estado; }

	    public Personas getSolicitante() { return solicitante; }
	    public void setSolicitante(Personas solicitante) { this.solicitante = solicitante; }

	    public List<Item> getItemsPrestados() { return itemsPrestados; }
	    public void setItemsPrestados(List<Item> itemsPrestados) { this.itemsPrestados = itemsPrestados; }
}

